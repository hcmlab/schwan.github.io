{
  "launcher": "slurm",
  "session_root": "${SWAN_SLURM_A100_SESSION_ROOT}",
  "data_root": "${SWAN_SLURM_A100_DATA_ROOT}",
  "output_root": "${SWAN_SLURM_A100_OUTPUT_ROOT}",
  "cache_root": "${SWAN_SLURM_A100_CACHE_ROOT}",
  "temp_root": "${SWAN_SLURM_A100_TEMP_ROOT}",
  "logs_root": "${SWAN_SLURM_A100_LOGS_ROOT}",
  "env_name": "swan",
  "python_bin": "python",
  "conda_activate": "${SWAN_SLURM_A100_CONDA_ACTIVATE}",
  "local_gpus": 1,
  "slurm": {
    "partition": null,
    "account": null,
    "qos": null,
    "gres": "gpu:a40:1",
    "cpus_per_task": 8,
    "mem": "64G",
    "time": "7-00:00:00",
    "array_parallelism": 3,
    "python_bin": "python",
    "extra_sbatch_args": []
  }
}
