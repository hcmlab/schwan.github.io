{
  "base_model": "zai-org/GLM-4.6V-Flash",
  "template": "glm4_5v",
  "modality": "video",
  "output_name": "glm46v_flash_no_bg",
  "trust_remote_code": true,
  "allow_quantization": true,
  "h100_full_precision_default": true,
  "train_defaults": {
    "stage": "sft",
    "do_train": true,
    "enable_thinking": false,
    "finetuning_type": "lora",
    "lora_target": "all",
    "lora_rank": 64,
    "lora_alpha": 128,
    "lora_dropout": 0.05,
    "cutoff_len": 8192,
    "quantization_bit": 4,
    "quantization_method": "bitsandbytes",
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "learning_rate": 5e-05,
    "num_train_epochs": 5,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.03,
    "bf16": true,
    "do_eval": true,
    "logging_steps": 10,
    "eval_strategy": "epoch",
    "save_strategy": "epoch",
    "save_total_limit": 2,
    "load_best_model_at_end": true,
    "save_on_each_node": false
  },
  "predict_defaults": {
    "cutoff_len": 8192,
    "do_sample": false,
    "max_new_tokens": 256,
    "per_device_eval_batch_size": 1,
    "bf16": true
  },
  "extra_config": {},
  "family": "vision_glm"
}
