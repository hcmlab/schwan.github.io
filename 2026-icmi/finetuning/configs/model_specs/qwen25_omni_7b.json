{
  "base_model": "Qwen/Qwen2.5-Omni-7B",
  "template": "qwen2_omni",
  "modality": "omni",
  "output_name": "qwen25_omni_7b",
  "trust_remote_code": true,
  "allow_quantization": true,
  "h100_full_precision_default": true,
  "train_defaults": {
    "stage": "sft",
    "do_train": true,
    "finetuning_type": "lora",
    "lora_target": "all",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "cutoff_len": 4096,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "learning_rate": 5e-05,
    "num_train_epochs": 5,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.03,
    "bf16": true,
    "do_eval": true,
    "eval_strategy": "steps",
    "eval_steps": 100,
    "save_strategy": "steps",
    "save_steps": 100,
    "save_total_limit": 2,
    "load_best_model_at_end": true,
    "metric_for_best_model": "eval_loss",
    "greater_is_better": false,
    "early_stopping_steps": 5,
    "save_on_each_node": false,
    "quantization_bit": 4,
    "quantization_method": "bitsandbytes"
  },
  "predict_defaults": {
    "cutoff_len": 4096,
    "do_sample": false,
    "max_new_tokens": 256,
    "per_device_eval_batch_size": 1,
    "bf16": true
  },
  "extra_config": {},
  "family": "omni_qwen"
}
