# ──────────────────────────────────────────────────────────────
# GPU Server Fine-Tuning Pipeline — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and adjust paths for your system.
# All scripts read these via os.environ with sane defaults.

# Root of the Schwan T3 FineTune dataset (mounted share on the VM)
DATA_ROOT=/mnt/data/Schwan_T3_FineTune

# Working output directory for pipeline artefacts
OUT_DIR=gpu_server/data
